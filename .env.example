# Admin panel credentials (optional — defaults to admin/admin123)
# Prefix PUBLIC_ is required for Astro client-side access
PUBLIC_ADMIN_USERNAME=admin
PUBLIC_ADMIN_PASSWORD=admin123

# Firebase web config. These ship to the browser, so they MUST be PUBLIC_
# prefixed for Astro to expose them client-side. (Firebase web config is not secret.)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
