---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhotoUpload from "../components/PhotoUpload.astro";
---

<BaseLayout title="Subir Fotos" skipPrivacyGate={true}>
  <main class="fotos-main">
    <header class="fotos-header">
      <a href="/" class="back-link">← Volver a la invitación</a>
      <h1>Comparte tus Fotos</h1>
      <p class="fotos-sub">
        Captura los momentos especiales del evento y compártelos con nosotros.
      </p>
    </header>

    <section class="fotos-section">
      <PhotoUpload />
    </section>
  </main>
</BaseLayout>

<style>
  .fotos-main {
    min-height: 100vh;
    padding: 2rem 1rem 3rem;
    max-width: 760px;
    margin-inline: auto;
  }

  .fotos-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.2rem;
    color: var(--primary);
    font-size: 1.05rem;
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .fotos-sub {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
  }

  .fotos-section {
    width: 100%;
  }
</style>

<!-- Light theme override scoped to this page (each Astro page is its own HTML document). -->
<style is:global>
  :root {
    --bg: #f7f4ee;
    --surface: #ffffff;
    --surface-soft: #f1ece2;
    --text: #2c2a27;
    --title: #2c2a27;
    --muted: #6e6a63;
    --line: #e2dcd0;
    --primary-soft: #f6efd8;
    --shadow-sm: 0 8px 20px rgba(40, 30, 15, 0.08);
    --shadow-md: 0 18px 34px rgba(40, 30, 15, 0.14);
  }

  button:hover {
    background: var(--primary-soft);
  }

  button:disabled {
    background: var(--surface-soft);
  }
</style>
