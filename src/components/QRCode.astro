---
// La URL del QR se deriva del dominio configurado en astro.config.mjs (`site`).
const photoUploadUrl = new URL("/fotos", Astro.site).toString();
const qrImageUrl = `https://quickchart.io/qr?text=${encodeURIComponent(photoUploadUrl)}&size=280`;
---

<div class="qr-section">
  <div class="qr-heading">
    <span class="qr-camera" aria-hidden="true">
      <img src="/camara.svg" alt="" class="qr-heading-icon" />
      <img src="/camara_flash.svg" alt="" class="qr-heading-icon-flash" />
    </span>
    <h2>Comparte tus Fotos</h2>
  </div>
  <p>Escanéalo desde tu celular para subir fotos del evento en segundos.</p>

  <div class="qr-container">
    <img
      class="qr-image"
      src={qrImageUrl}
      alt="Código QR para subir fotos del evento"
      loading="lazy"
    />
    <p class="qr-link">{photoUploadUrl}</p>
  </div>

  <a href="/fotos" class="qr-upload-btn">
    <img src="/camara.svg" alt="" class="qr-upload-btn-icon" aria-hidden="true" />
    Subir fotos
  </a>

  <p class="qr-note">
    Escanea el código o pulsa el botón para subir tus fotos del evento.
  </p>
</div>

<style>
  .qr-section {
    text-align: center;
    padding: 1.6rem;
    background: var(--surface);
    border-radius: 0;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    max-width: none;
    margin: 0;
  }

  .qr-container {
    margin: 1.1rem auto 0;
    padding: 1.2rem;
    max-width: 380px;
    background: #f7efe3;
    border-radius: 0;
    border: 1px solid #e5d4bf;
  }

  .qr-heading {
    width: 100%;
    display: grid;
    justify-items: center;
    gap: 0.3rem;
  }

  .qr-camera {
    position: relative;
    width: 64px;
    height: 64px;
    display: inline-block;
  }

  .qr-heading-icon,
  .qr-heading-icon-flash {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }

  .qr-heading-icon-flash {
    opacity: 0;
    animation: qr-camera-flash 2.4s ease-in-out infinite;
  }

  .qr-image {
    width: min(280px, 70vw);
    height: auto;
    border: 8px solid #fff;
    box-shadow: 0 10px 22px rgba(88, 63, 43, 0.12);
  }

  .qr-link {
    margin-top: 1rem;
    word-break: break-all;
    font-size: 1.05rem;
  }

  .qr-note {
    margin-top: 0.9rem;
    font-size: 1.05rem;
    color: var(--muted);
  }

  .qr-upload-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.1rem;
    padding: 0.8rem 1.6rem;
    border-radius: 999px;
    background: var(--primary);
    border: 1px solid var(--primary);
    color: #0d0d0d;
    font-weight: 700;
    font-size: 1.15rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }

  .qr-upload-btn:hover {
    transform: translateY(-2px);
    background: var(--primary-soft);
    color: var(--primary);
  }

  .qr-upload-btn-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  @keyframes qr-camera-flash {
    0%,
    85%,
    100% {
      opacity: 0;
    }
    90%,
    95% {
      opacity: 1;
    }
  }
</style>
