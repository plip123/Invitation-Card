---
interface Props {
  title: string;
  skipPrivacyGate?: boolean;
}

const { title, skipPrivacyGate = false } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Invitación XV Años — Antonella Di Maggio" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon-rings.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    {
      skipPrivacyGate ? (
        <slot />
      ) : (
        <>
          <main id="privacy-gate" class="privacy-gate-main">
            <section class="privacy-gate-card" aria-label="Acceso privado">
              <h1>Acceso privado</h1>
              <p>Ingresa el código de tu invitación para continuar.</p>
              <form id="privacy-gate-form" class="privacy-gate-form">
                <input
                  id="privacy-gate-input"
                  type="text"
                  name="codigo"
                  autocomplete="off"
                  placeholder="Código de acceso"
                  required
                />
                <button id="privacy-gate-submit" type="submit">Ingresar</button>
              </form>
              <p id="privacy-gate-error" class="privacy-gate-error" hidden>
                El código no es válido. Revisa el enlace de tu invitación.
              </p>
            </section>
          </main>
          <div id="privacy-app-content" hidden>
            <slot />
          </div>
          <script>
            import { validateRSVPToken } from '../lib/rsvp';

            const gate = document.getElementById('privacy-gate') as HTMLElement | null;
            const appContent = document.getElementById('privacy-app-content') as HTMLElement | null;
            const gateForm = document.getElementById('privacy-gate-form') as HTMLFormElement | null;
            const gateInput = document.getElementById('privacy-gate-input') as HTMLInputElement | null;
            const gateError = document.getElementById('privacy-gate-error') as HTMLElement | null;
            const gateSubmit = document.getElementById('privacy-gate-submit') as HTMLButtonElement | null;

            if (!gate || !appContent || !gateForm || !gateInput) {
              throw new Error('Privacy gate initialization failed.');
            }

            const getCodeFromUrl = () => {
              const params = new URLSearchParams(window.location.search);
              return params.get('codigo')?.trim() || params.get('token')?.trim() || '';
            };

            const setFormState = (isLoading: boolean) => {
              if (gateSubmit) {
                gateSubmit.disabled = isLoading;
                gateSubmit.textContent = isLoading ? 'Validando...' : 'Ingresar';
              }
              gateInput.disabled = isLoading;
            };

            const showError = (message?: string) => {
              if (!gateError) return;
              gateError.textContent = message || 'Ingresa cualquier código para continuar.';
              gateError.hidden = false;
            };

            const hideError = () => {
              if (gateError) gateError.hidden = true;
            };

            const openApp = () => {
              gate.hidden = true;
              appContent.hidden = false;
            };

            const attemptUnlock = async (code: string) => {
              setFormState(true);
              hideError();
              // Solo se permite el acceso si el código corresponde a una
              // invitación real registrada en Firestore.
              const guest = code ? await validateRSVPToken(code) : null;
              setFormState(false);

              if (!guest) {
                showError('El código no es válido. Revisa el enlace de tu invitación.');
                return false;
              }

              openApp();

              // Recordar el código para reusarlo al volver desde otras páginas
              // (p. ej. el "Volver a la invitación" de /fotos).
              try {
                localStorage.setItem('weddingGuestCode', code);
              } catch {}

              window.dispatchEvent(
                new CustomEvent('guest-identified', { detail: guest }),
              );

              return true;
            };

            const initialCode = getCodeFromUrl();
            if (initialCode) {
              gateInput.value = initialCode;
              void attemptUnlock(initialCode);
            }

            gateForm.addEventListener('submit', async (event) => {
              event.preventDefault();
              const code = gateInput.value.trim();
              if (!code) {
                showError('Debes ingresar un código de invitación.');
                return;
              }

              const unlocked = await attemptUnlock(code);
              if (!unlocked) return;

              const nextUrl = new URL(window.location.href);
              nextUrl.searchParams.set('codigo', code);
              window.history.replaceState({}, '', nextUrl.toString());
            });
          </script>
        </>
      )
    }
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #111214;
    --surface: #1A1A1C;
    --surface-soft: #222226;
    --text: #E8E0D0;
    --muted: #999B9B;
    --line: #2E2E32;
    --primary: #D4AF37;
    --primary-soft: #1F1A0A;
    --success: #8A9597;
    --danger: #C0504D;
    --radius-lg: 18px;
    --radius-md: 12px;
    --shadow-sm: 0 10px 24px rgba(0, 0, 0, 0.35);
    --shadow-md: 0 22px 40px rgba(0, 0, 0, 0.50);
    --font-body: "Cormorant Garamond", Georgia, serif;
    --font-script: "Great Vibes", cursive;
  }

  html {
    font-family: var(--font-body);
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    line-height: 1.6;
    color: var(--text);
    background: var(--bg);
    background-attachment: scroll;
    letter-spacing: 0.01em;
  }

  .privacy-gate-main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .privacy-gate-card {
    width: min(100%, 440px);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1.6rem 1.4rem;
    text-align: center;
  }

  .privacy-gate-card h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .privacy-gate-card > p {
    margin-bottom: 0.75rem;
  }

  .demo-hint {
    background: #1A1A0A;
    border: 1px solid #2E2A10;
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
    font-size: 1.05rem;
    color: var(--primary);
    margin-bottom: 1rem !important;
    text-align: left;
  }

  .privacy-gate-form {
    display: grid;
    gap: 0.65rem;
  }

  .privacy-gate-form input {
    margin-bottom: 0;
  }

  .privacy-gate-error {
    color: var(--danger);
    margin-top: 0.75rem;
    margin-bottom: 0;
    font-size: 1.05rem;
  }

  section {
    padding: 0;
    max-width: none;
    margin: 0;
    background: var(--bg);
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    text-align: center;
    color: var(--text);
    font-weight: 600;
  }

  h2 {
    font-size: 2.35rem;
    margin-bottom: 1rem;
    text-align: center;
    color: var(--text);
    font-weight: 600;
  }

  h3 {
    font-size: 1.42rem;
    margin-bottom: 0.75rem;
    color: var(--text);
    font-weight: 600;
  }

  p {
    margin-bottom: 1rem;
    font-size: 1.32rem;
    color: var(--muted);
  }

  a {
    color: var(--primary);
  }

  button {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0.75rem 1.3rem;
    font-size: 1.16rem;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--text);
    font-weight: 600;
    font-family: inherit;
  }

  button:hover {
    background: #1F1A0A;
    transform: translateY(-1px);
  }

  button:disabled {
    background: #222226;
    cursor: not-allowed;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.75rem;
    margin-bottom: 1rem;
    border: 1px solid var(--line);
    background: var(--bg);
    border-radius: 5px;
    font-size: 1.16rem;
    font-family: inherit;
    color: var(--text);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.18);
  }

  @media (max-width: 768px) {
    section {
      padding: 0;
    }

    h1 {
      font-size: 2rem;
    }

    h2 {
      font-size: 1.5rem;
    }

    h3 {
      font-size: 1.25rem;
    }

    p {
      font-size: 1.12rem;
    }
  }

  .section-heading-icon, .detail-icon, .gift-heading-icon, .song-heading-icon, .qr-heading-icon {
    filter: brightness(0) invert(0.85);
  }
</style>
